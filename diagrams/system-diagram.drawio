        <mxCell id="bot" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="Discord Bot&#xa;discord.js · Gemini 2.0 Flash&#xa;template fallback (never silent)" vertex="1">
          <mxGeometry height="90" width="210" x="870" y="180" as="geometry" />
        </mxCell>
        <mxCell id="dash" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="Next.js Dashboard&#xa;device panel · power meter&#xa;alerts panel · floor plan" vertex="1">
