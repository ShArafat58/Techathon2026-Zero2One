<mxfile host="app.diagrams.net">
  <diagram name="OfficeWatch System" id="officewatch-sys">
    <mxGraphModel dx="1414" dy="743" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="750" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="dev" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Simulated Device Layer&#xa;15 devices — 3 rooms × (2 fans + 3 lights)&#xa;status · watts · room · lastChanged" vertex="1">
          <mxGeometry height="100" width="220" y="300" as="geometry" />
        </mxCell>
        <mxCell id="esp" parent="1" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#f5f5f5;strokeColor=#666666;" value="Real-world equivalent:&#xa;ESP32 + switches/sensors&#xa;(Wokwi concept — same JSON payload)" vertex="1">
          <mxGeometry height="90" width="220" x="40" y="470" as="geometry" />
        </mxCell>
        <mxCell id="sim" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Simulator&#xa;5s tick · office-hours-aware behaviour" vertex="1">
          <mxGeometry height="70" width="210" x="330" y="150" as="geometry" />
        </mxCell>
        <mxCell id="store" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1" value="In-Memory State Store&#xa;(single source of truth)" vertex="1">
          <mxGeometry height="100" width="210" x="330" y="300" as="geometry" />
        </mxCell>
        <mxCell id="alert" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Alert Engine&#xa;after-hours rule · 2h-continuous rule&#xa;10-min cooldown" vertex="1">
          <mxGeometry height="80" width="210" x="330" y="480" as="geometry" />
        </mxCell>
        <mxCell id="rest" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="REST API (Express)&#xa;/devices /rooms /usage /alerts" vertex="1">
          <mxGeometry height="70" width="190" x="620" y="80" as="geometry" />
